---
import { Image } from 'astro:assets'
import SectionTitle from './ui/SectionTitle.astro'
import Typography from './ui/Typography.astro'

interface Partner {
  name: string
  role: string
  image: string
  description: string
  specialties: string[]
}

const partners: Partner[] = [
  {
    name: 'Dra. Nathalia Zúñiga Ordoñez',
    role: 'Abogada, Magíster en Arbitraje Internacional y mediadora certificada',
    image: '/images/partners/nathalia-zuniga.png',
    description:
      'Brinda asesoría especializada en mecanismos alternativos de resolución de conflictos, promoviendo soluciones ágiles, efectivas y consensuadas. Cuenta con amplia experiencia en las áreas de Derecho de Familia, Derecho Civil y Derecho Notarial, Derecho Administrativo y Derecho Societario.',
    specialties: ['Arbitraje Internacional', 'Mediación', 'Derecho de Familia'],
  },
  {
    name: 'Dra. Patricia Ordoñez Muñoz',
    role: 'Abogada especialista en Derecho penal, constitucional y justicia penal militar',
    image: '/images/partners/nathalia-zuniga.png',
    description:
      'Cuenta además con amplia experiencia en las áreas de Derecho de Familia, Derecho Civil, Derecho Administrativo y Derecho Societario.',
    specialties: [
      'Derecho Penal',
      'Derecho Constitucional',
      'Justicia Penal Militar',
    ],
  },
]
---

<section id='nosotros' class='py-24 overflow-hidden relative'>
  <div class='container mx-auto mt-5'>
    <h2 class='text-4xl font-bold text-left mb-12'>
      <Typography>Sobre Nosotros</Typography>
    </h2>

    <!-- Contenido -->
    <div class='grid lg:grid-cols-2 gap-12 lg:gap-16 xl:gap-24 items-start'>
      <div class='space-y-8'>
        <h3 class='text-3xl font-bold text-gradient-primary'>
          Experiencia y compromiso en cada caso
        </h3>

        <p class='text-xl text-foreground leading-relaxed'>
          Nos enorgullece ofrecer un servicio legal integral, donde cada caso
          recibe la atención personalizada que merece.
        </p>

        <div class='pt-4'>
          <a href='#equipo' class='btn btn-primary btn-base'>
            Conoce a Nuestro Equipo
          </a>
        </div>
      </div>

      <div class='grid gap-4'>
        <div
          class='flex items-center gap-4 bg-light/5 rounded-lg hover:bg-light/10 transition-colors invisible intersect:visible intersect:animate-fade-left intersect-once'
        >
          <Image
            width={80}
            height={80}
            src='/images/png-icons/legal.png'
            alt='imagen de asuntos legales'
            class='max-w-20'
          />
          <div class='ml-2'>
            <h3 class='text-xl font-semibold text-primary mb-2'>
              Experiencia Legal Integral
            </h3>
            <p class='text-foreground/90'>
              Nuestro equipo de abogados especializados ofrece soluciones
              legales completas y personalizadas para cada cliente, asegurando
              la mejor representación en cada caso.
            </p>
          </div>
        </div>

        <div
          class='flex items-center gap-4 bg-light/5 rounded-lg hover:bg-light/10 transition-colors invisible intersect:visible intersect:animate-fade-left intersect-once'
        >
          <Image
            width={80}
            height={80}
            src='/images/png-icons/compromiso.png'
            alt='imagen de compromiso'
            class='max-w-20'
          />
          <div class='ml-2'>
            <h3 class='text-xl font-semibold text-primary mb-2'>
              Compromiso Total
            </h3>
            <p class='text-foreground/90'>
              Nos dedicamos a entender completamente las necesidades de nuestros
              clientes, manteniéndolos informados y acompañados durante todo el
              proceso legal.
            </p>
          </div>
        </div>

        <div
          class='flex items-center gap-4 bg-light/5 rounded-lg hover:bg-light/10 transition-colors invisible intersect:visible intersect:animate-fade-left intersect-once'
        >
          <Image
            width={80}
            height={80}
            src='/images/png-icons/respuesta.png'
            alt='imagen de respuesta inmediata'
            class='max-w-20'
          />
          <div class='ml-2'>
            <h3 class='text-xl font-semibold text-primary mb-2'>
              Respuesta Inmediata
            </h3>
            <p class='text-foreground/90'>
              Entendemos la importancia de la rapidez en asuntos legales.
              Nuestro equipo está siempre disponible para responder a sus
              necesidades de manera oportuna y eficiente.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Socios -->
    <div id='equipo' class='mt-24'>
      <SectionTitle title='Nuestros Socios' />

      <div class='grid gap-8 md:grid md:grid-cols-2 md:gap-12 xl:max-w-3xl xl:mx-auto'>
        {
          partners.map((partner) => (
            <article class='bg-light/5 rounded-xl overflow-hidden hover:bg-light/10 transition-all duration-300 shadow-md hover:shadow-lg invisible intersect:visible intersect:animate-fade-up intersect-half intersect-once'>
              <div class='aspect-[4/3] overflow-hidden'>
                <Image
                  width={400}
                  height={300}
                  src={partner.image}
                  alt={partner.name}
                  class='w-full h-full object-cover hover:scale-105 transition-transform duration-300'
                />
              </div>
              <div class='p-6 space-y-4'>
                <div>
                  <h3 class='text-xl font-bold text-primary'>{partner.name}</h3>
                  <p class='text-foreground/60 text-sm'>{partner.role}</p>
                </div>
                <p class='text-foreground/90 text-sm leading-relaxed'>
                  {partner.description}
                </p>
                <div class='flex flex-wrap gap-2'>
                  {partner.specialties.map((specialty) => (
                    <span class='text-xs px-2 py-1 bg-primary/10 text-black rounded-full'>
                      {specialty}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>

  <div class='custom-shape-divider-top-1758733725'>
    <svg
      data-name='Layer 1'
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 1200 120'
      preserveAspectRatio='none'
    >
      <path d='M1200 120L0 16.48 0 0 1200 0 1200 120z' class='shape-fill'
      ></path>
    </svg>
  </div>
</section>

<style>
  .custom-shape-divider-top-1758733725 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .custom-shape-divider-top-1758733725 svg {
    position: relative;
    display: block;
    width: calc(189% + 1.3px);
    height: 156px;
  }

  .custom-shape-divider-top-1758733725 .shape-fill {
    fill: #bf8e8a;
  }
</style>
