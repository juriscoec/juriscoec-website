<style>
  .wa-widget {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 60;
    width: min(280px, calc(100vw - 20px));
  }

  .wa-panel {
    border-radius: 16px;
    overflow: hidden;
    background: #dfe2df;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.25);
    border: 1px solid rgb(0 0 0 / 0.1);
    opacity: 0;
    transform: translateY(14px) scale(0.96);
    transform-origin: bottom right;
    visibility: hidden;
    pointer-events: none;
    will-change: transform, opacity;
    transition:
      opacity 220ms ease,
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 280ms;
  }

  .wa-panel.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 220ms ease,
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0s;
  }

  .wa-header {
    height: 42px;
    background: #25d366;
    color: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px;
    font-size: 11px;
  }

  .wa-close {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    border: 0;
    background: rgb(0 0 0 / 0.15);
    color: #fff;
    cursor: pointer;
    line-height: 1;
  }

  .wa-body {
    margin: 12px;
    border-radius: 12px;
    background: #f5f5f5;
    border: 2px solid #d9d9d9;
    padding: 10px 12px;
    color: #4a4a4a;
    font-size: 13px;
  }

  .wa-body p {
    margin: 0;
  }

  .wa-open {
    margin: 0 12px 12px;
    border-radius: 999px;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    height: 38px;
    display: inline-flex;
    width: calc(100% - 24px);
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
  }

  .wa-open svg {
    width: 18px;
    height: 18px;
  }

  .wa-fab {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: #25d366;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.25);
  }

  .wa-fab-icon {
    width: 28px;
    height: 28px;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 640px) {
    .wa-widget {
      right: 10px;
      bottom: 10px;
      width: min(260px, calc(100vw - 16px));
    }
  }
</style>

<script>
  const root = document.getElementById('wa-widget')
  if (root) {
    const panel = root.querySelector('[data-panel]')
    const closeButton = root.querySelector('[data-close]')
    const fab = root.querySelector('[data-fab]')

    closeButton?.addEventListener('click', () => {
      panel?.classList.remove('is-open')
      fab?.classList.remove('hidden')
    })

    fab?.addEventListener('click', (event) => {
      event.preventDefault()
      panel?.classList.add('is-open')
      fab?.classList.add('hidden')
    })
  }
</script>
