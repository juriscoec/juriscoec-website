---
import { Image } from 'astro:assets'
import facebookIcon from '../assets/social/facebook.svg?raw'
import instagramIcon from '../assets/social/instagram.svg?raw'
import linkedinIcon from '../assets/social/linkedin.svg?raw'
import twitterIcon from '../assets/social/twitter.svg?raw'

const currentYear = new Date().getFullYear()

const navigationLinks = [
  { href: '#nosotros', text: 'Nosotros' },
  { href: '#equipo', text: 'Equipo' },
  { href: '#legal', text: 'Legal' },
  { href: '#contacto', text: 'Contacto' },
]

const socialMedia = [
  {
    name: 'Facebook',
    url: 'https://facebook.com',
    icon: facebookIcon,
  },
  {
    name: 'Twitter',
    url: 'https://twitter.com',
    icon: twitterIcon,
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com',
    icon: linkedinIcon,
  },
  {
    name: 'Instagram',
    url: 'https://instagram.com',
    icon: instagramIcon,
  },
]

const contactInfo = {
  address:
    'Calle General Maldonado entre Av. Amazonas y Antonia Vela, Edificio Lexus, Ofi. 105',
  phonePrimary: '0981692167',
  phoneSecondary: '0989627532',
  email: 'abogadazo@juriscoec.com',
  hours:
    'Lunes a viernes: 8:30 a 5:30. Atención fin de semana con cita previa.',
}
---

<footer class='bg-black text-light'>
  <div class='container mx-auto pt-12 pb-6'>
    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8'>
      <!-- Logo y descripción -->
      <div class='space-y-4'>
        <Image
          width={80}
          height={50}
          src='/images/logo.webp'
          alt='Juriscoec Logo'
          class='h-12 object-contain'
        />
        <p class='text-light/80 text-sm leading-relaxed'>
          Firma de abogados especializada en brindar soluciones legales
          integrales con compromiso, profesionalismo y excelencia.
        </p>
      </div>

      <!-- Enlaces de navegación -->
      <div class='lg:ml-10'>
        <h3 class='font-great-vibes text-3xl md:text-4xl mb-4'>Navegación</h3>
        <ul class='space-y-2'>
          {
            navigationLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class='text-light/80 hover:text-primary transition-colors duration-200 text-sm'
                >
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Información de contacto -->
      <div>
        <h3 class='font-great-vibes text-3xl md:text-4xl mb-4'>Contacto</h3>
        <ul class='space-y-3 text-sm'>
          <li class='flex items-start gap-2'>
            <span class='text-primary mt-0.5'>📍</span>
            <span class='text-light/80'>{contactInfo.address}</span>
          </li>
          <li class='flex items-center gap-2'>
            <span class='text-primary'>📞</span>
            <a
              href='tel:+593981692167'
              class='text-light/80 hover:text-primary transition-colors duration-200'
            >
              {contactInfo.phonePrimary}
            </a>
          </li>
          <li class='flex items-center gap-2'>
            <span class='text-primary'>📞</span>
            <a
              href='tel:+593989627532'
              class='text-light/80 hover:text-primary transition-colors duration-200'
            >
              {contactInfo.phoneSecondary}
            </a>
          </li>
          <li class='flex items-center gap-2'>
            <span class='text-primary'>✉️</span>
            <a
              href={`mailto:${contactInfo.email}`}
              class='text-light/80 hover:text-primary transition-colors duration-200'
            >
              {contactInfo.email}
            </a>
          </li>
          <li class='flex items-start gap-2'>
            <span class='text-primary mt-0.5'>⏰</span>
            <span class='text-light/80'>{contactInfo.hours}</span>
          </li>
        </ul>
      </div>

      <!-- Redes Sociales -->
      <div class='lg:ml-14'>
        <h3 class='font-great-vibes text-3xl md:text-4xl mb-4'>Síguenos</h3>
        <div class='flex gap-3'>
          {
            socialMedia.map((social) => (
              <a
                href={social.url}
                target='_blank'
                rel='noopener noreferrer'
                class='w-10 h-10 flex items-center justify-center bg-light/10 rounded-full hover:bg-primary hover:scale-110 transition-all duration-300 group'
                aria-label={social.name}
              >
                <span
                  class='block h-5 w-5 text-light group-hover:text-dark transition-colors'
                  aria-hidden='true'
                  set:html={social.icon}
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class='mt-12 pt-6 border-t border-light/10 text-center'>
      <p class='text-light/60 text-sm'>
        © {currentYear} Juriscoec. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
